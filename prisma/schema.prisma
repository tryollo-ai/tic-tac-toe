// Prisma schema for tic-tac-toe persistence (issue #49).
//
// Persistence target is Postgres (Neon in production). Timestamps are stored as
// `timestamptz` (Prisma `DateTime`), NOT epoch-ms integers - this is a deliberate
// decision so the database holds real instants. The in-memory store still uses
// epoch-ms numbers; conversion happens at the (future) store boundary.
//
// Model field names stay camelCase for ergonomic use from TypeScript, while the
// underlying tables/columns are snake_case via @map/@@map for idiomatic SQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Server-wide config for the internal POC toggles (currently just which
/// ShiftMode new shifts use). A single row keyed by a fixed id, so the active
/// mode survives restarts and is shared across serverless instances - unlike the
/// old in-memory value, which reset to the default on every restart.
model AppConfig {
  id        String @id
  shiftMode String @default("classic") @map("shift_mode")
  /// Side length new games are created at, and the consecutive run needed to win
  /// them. Like shiftMode these govern only *new* games; each game records the
  /// size/run it was created with, so changing these never rewrites history.
  boardSize Int    @default(3) @map("board_size")
  winLength Int    @default(3) @map("win_length")

  @@map("app_config")
}

/// A live, replayable room. Mirrors `Room` in lib/roomTypes.ts, flattening the
/// nested scores/seats/seatSeen objects into columns.
model Room {
  id          String   @id
  name        String
  board       Json
  /// Board side length and the consecutive run needed to win, fixed for the
  /// room's life at creation from the active config.
  size        Int      @default(3)
  winLength   Int      @default(3) @map("win_length")
  /// Every action this round, in turn order; X takes even indices, O odd.
  actions     Json
  xIsNext     Boolean  @map("x_is_next")
  scoreX      Int      @default(0) @map("score_x")
  scoreO      Int      @default(0) @map("score_o")
  scoreDraws  Int      @default(0) @map("score_draws")
  seatX       String?  @map("seat_x")
  seatO       String?  @map("seat_o")
  /// Display name the seat holder chose, shown to both players so they can see
  /// who they're playing against. Null when the seat is open or its holder gave
  /// no name; cleared alongside the seat on leave/sweep and swapped with it.
  seatXName   String?  @map("seat_x_name")
  seatOName   String?  @map("seat_o_name")
  seatSeenX   DateTime? @map("seat_seen_x") @db.Timestamptz
  seatSeenO   DateTime? @map("seat_seen_o") @db.Timestamptz
  mode        String
  /// Whether O has spent its one-time whole-grid shift this round.
  oShiftUsed  Boolean  @default(false) @map("o_shift_used")
  /// Whether X has spent its one-time (conditional, classic-only) grid shift this round.
  xShiftUsed  Boolean  @default(false) @map("x_shift_used")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  lastActivity DateTime @map("last_activity") @db.Timestamptz

  @@index([lastActivity])
  @@map("rooms")
}

/// A live viewer-presence heartbeat: one row per (room, viewer) currently
/// watching a room. Purely liveness, never game state - it is rewritten on every
/// stream/poll tick and swept by TTL exactly like the seat heartbeats, and used
/// only to count how many people are viewing a room at any moment. A composite
/// (room, player) key makes each viewer at most one row, so the count is a simple
/// `COUNT(*)` over the room's un-expired rows.
model RoomParticipant {
  roomId   String   @map("room_id")
  playerId String   @map("player_id")
  lastSeen DateTime @map("last_seen") @db.Timestamptz

  @@id([roomId, playerId])
  @@index([roomId, lastSeen])
  @@map("room_participants")
}

/// An archived, finished game. Mirrors `CompletedGame` in lib/roomTypes.ts. The
/// ordered action log is the single source of truth; the final board/winner are
/// derived from it at read time.
model CompletedGame {
  id          String   @id
  roomId      String   @map("room_id")
  name        String
  mode        String
  /// Board side length and win run length the game was played at, so its replay
  /// rebuilds at the right size regardless of the current config.
  size        Int      @default(3)
  winLength   Int      @default(3) @map("win_length")
  /// Every action in play order; X takes even indices, O odd.
  actions     Json
  /// Seat holders at archive time, so a game can be shown only to its players.
  /// O is the AI sentinel in AI rooms; both are null for games archived before
  /// this was recorded (they belong to no player and stay hidden).
  playerX     String?  @map("player_x")
  playerO     String?  @map("player_o")
  completedAt DateTime @default(now()) @map("completed_at") @db.Timestamptz

  @@index([completedAt])
  @@index([playerX])
  @@index([playerO])
  @@map("completed_games")
}
