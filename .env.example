# Postgres connection string for the room-persistence layer (issue #49).
#
# In production this points at a Neon (https://neon.tech) Postgres database.
# Create a Neon project, then copy its pooled connection string from the Neon
# dashboard (Connection Details) and paste it below. Neon requires SSL, so keep
# the `?sslmode=require` suffix.
#
# Do NOT commit a real connection string. Copy this file to `.env.local`
# (gitignored) and fill in real values there:
#
#   cp .env.example .env.local
#
# See docs/database.md for the full setup and migration guide.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
